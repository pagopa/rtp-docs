@startuml
!theme materia

title RTP Send Flow

participant "RTP-CONSUMER" as CONSUMER
participant "MS-SENDER" as SENDER
participant "SPD" as SPD

autonumber

CONSUMER -> SENDER: POST /gpd/message
activate SENDER

SENDER -> SENDER: validate payload

SENDER -> SENDER: determine operation type\n(CREATE, UPDATE, DELETE)

alt CREATE
    SENDER -> SPD: SEND RTP
    note right of SPD: See diagram: RTP Create Flow
    activate SPD
    SPD --> SENDER: OK
    deactivate SPD

else UPDATE
    SENDER -> SPD: CANCEL RTP (RFC)
    note right of SPD: See diagram: RTP RFC Flow
    activate SPD
    SPD --> SENDER: OK
    deactivate SPD
    SENDER -> SPD: SEND RTP
    note right of SPD: See diagram: RTP Create Flow
    activate SPD
    SPD --> SENDER: OK
    deactivate SPD

else DELETE
    SENDER -> SPD: CANCEL RTP (RFC)
    note right of SPD: See diagram: RTP RFC Flow
    activate SPD
    SPD --> SENDER: OK
    deactivate SPD
end

deactivate SENDER

@enduml
