@startuml

!theme materia

title RTP Notice Status API: GET /rtps/delivery-status?noticeNumber={nav}&payeeId={payeeId}

actor "Service Provider" as Client
participant "SendAPIControllerImpl" as Controller
participant "SendRTPServiceImpl" as Service
participant "RtpRepository\n(Cosmos API Mongo)" as Repository
participant "Azure Data Explorer" as ADX

Client -> Controller : GET /rtps/delivery-status?noticeNumber={nav}&payeeId={payeeId}
activate Controller
note right of Controller : @PreAuthorize("hasRole('payee_read_rtp')")

alt Valid request

    Controller -> Service : findByNoticeNumber(noticeNumber)
    activate Service

    par Query Cosmos
        Service -> Repository : findAllByNoticeNumber(noticeNumber)
        activate Repository
        Repository --> Service : Flux<Rtp>
        deactivate Repository
    else Query ADX
        Service -> ADX : findByNoticeNumber(noticeNumber)
        activate ADX
        ADX --> Service : Flux<Rtp>
        deactivate ADX
    end

    Service -> Service : merge results into Flux<Rtp>
    Service --> Controller : Flux<Rtp>
    deactivate Service

    Controller -> Service : getRtpDeliveryStatus(rtpFlux, payeeId)
    activate Service
    Service -> Service : filter by payeeId
    Service -> Service : filter by event in [SEND_RTP, ERROR_SEND_RTP]

    alt matching RTP found
        Service -> Service : map to RtpDeliveryResponseDto(PD_RTP_DELIVERED)
        Service --> Controller : RtpDeliveryResponseDto
    else no matching RTP found
        Service -> Service : return RtpDeliveryResponseDto(PD_RTP_NOT_DELIVERED)
        Service --> Controller : RtpDeliveryResponseDto
    end

    deactivate Service
    Controller --> Client : 200 OK\nRtpDeliveryResponseDto

else Errors

    group Client-Side Errors
        Controller --> Client : 400 Bad Request\n(e.g. invalid noticeNumber, missing payeeId)
        Controller --> Client : 401 Unauthorized\n(e.g. invalid or expired security token)
        Controller --> Client : 403 Forbidden\n(e.g. insufficient permissions)
        Controller --> Client : 429 Too Many Requests\n(e.g. rate limit exceeded)
    end group

    group Server-Side Error
        Controller --> Client : 500 Internal Server Error
    end group

end

deactivate Controller

@enduml