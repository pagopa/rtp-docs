@startuml
' PlantUML Diagram for RTP Cancellation API
' Title: Unified RTP Cancellation Sequence Diagram
' Version: 1.0.0
' Description: This diagram shows the detailed process for cancelling an RTP,
'              mixing the API specification with the actual Java service and controller logic.

!theme materia

title RTP Delete Flow

participant "MS-SENDER" as SENDER
database "RTPS" as SRTP
participant "DSP" as DSP

autonumber

[o-> SENDER: GDP DELETE event

activate SENDER
SENDER -> SRTP: findRtpByOperationDispatcherKey
  activate SRTP

alt RTP Found
    SRTP --> SENDER: RTP Found
    deactivate SRTP
    SENDER -> SENDER: validate RTP status
    SENDER -> SENDER: update RTP status (RFC_SENT)
    note right: Cancellation request initiated
    SENDER -> DSP: Send request of cancellation\nPOST /sepa-request-to-pay-requests/{sepaRequestToPayRequestResourceId}/cancellation-requests
    activate DSP
    note left of DSP
      Retry if failed
    end note

    alt Async flow EPC
      DSP --> SENDER: OK empty Body
      SENDER -> SENDER: update RTP status (RFC_SENT)
    else Sync flow EPC
      DSP --> SENDER: OK payload
      SENDER -> SENDER: update RTP status (CANCELLED)
    else Error Sync Response
      DSP --> SENDER: Error
      SENDER -> SENDER: update RTP status (ERROR_CANCEL)
    deactivate DSP
    end Error RFC



else RTP Not Found
    SRTP --> SENDER: not found
end


deactivate SENDER

@enduml