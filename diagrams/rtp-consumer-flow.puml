@startuml
title RTP Consumer — Message flow (GPD -> RTP)

queue "GPD EventHub" as EH
participant "rtp-consumer" as C
participant "mil-auth" as MA
participant "rtp-sender" as S
participant "rtp-activator" as A
queue "Dead-letter queue" as DLQ

EH -> C : Message payload
C -> C : Validate payload

alt Validation OK
  C -> MA : POST /token
  MA --> C : 200 OK (token)

  C -> S : POST /gpd/message (payload + token)

  alt POST OK
    S -> MA : POST /token
    MA --> S : 200 OK (token)

    S -> A : GET /activations/payer
    A --> S : 200 OK (payer)

    S --> C : 200 OK (RTP)
    C --> EH : Ack

  else POST failed (4xx / 5xx / timeout)
    S --> C : Error / timeout

    C -> DLQ : Enqueue failure payload
    DLQ --> C : Ack (DLQ)
    C --> EH : Ack
  end

else Validation failed
  C -> DLQ : Enqueue invalid payload
  note right of DLQ
    Malformed or invalid message.
  end note
  DLQ --> C : Ack (DLQ)
  C --> EH : Ack
end

deactivate C
@enduml